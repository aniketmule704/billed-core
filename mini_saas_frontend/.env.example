# Production Environment Variables
# Add these in Vercel Dashboard → Settings → Environment Variables

# ============ REQUIRED ============

# OCR Backend (production)
NEXT_PUBLIC_OCR_API_URL=https://billedcore2.onrender.com

# Razorpay Payments (Get from https://dashboard.razorpay.com/app/keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# Session Security (generate your own - 32+ random chars)
SESSION_SECRET=any-random-32-character-string

# ============ FIREBASE (REQUIRED FOR AUTH & PUSH) ============

# Get these from your Firebase Console -> Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcde

# Get this from Firebase Console -> Cloud Messaging -> Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=xxx

# Supabase (optional - currently not required, we use Dexie.js)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=xxx

# Sentry Error Tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx