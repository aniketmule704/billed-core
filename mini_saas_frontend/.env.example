# BillZo Environment Variables
# Add these in Vercel Dashboard → Settings → Environment Variables

# ============ REQUIRED ============

# Database (Neon PostgreSQL)
# Get from: https://console.neon.tech
# IMPORTANT: Use postgres:// (not postgresql://) for pg library compatibility
DATABASE_URL=postgres://user:password@host.neon.tech/db?sslmode=require

# Redis (Upstash)
# Get from: https://console.upstash.io
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Session Security (generate your own)
SESSION_SECRET=any-random-32-character-string

# Encryption Key (generate your own - 32 bytes)
CREDENTIAL_ENCRYPTION_KEY=billzo-encryption-key-32bytes!!

# ============ OPTIONAL ============

# n8n (Workflow Automation)
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/xxx
# N8N_WEBHOOK_SECRET=your-secret

# ERPNext (Accounting Backend)
# ERP_URL=http://localhost:8000
# ERP_API_KEY=administrator
# ERP_API_SECRET=admin

# Razorpay (Payments)
# Get from: https://dashboard.razorpay.com/app/keys
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx

# WhatsApp (Gupshup)
# WHATSAPP_PROVIDER=gupshup
# GUPSHUP_API_KEY=xxx

# Sentry (Error Tracking) - Optional
# Get from: https://sentry.io
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# OTP (SMS/WhatsApp) - Default is mock for development
# Set to 'false' to enable real SMS provider
OTP_MOCK=true

# Twilio (when OTP_MOCK=false)
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_PHONE_NUMBER=+1234567890