{
  "name": "billzo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "start": "pnpm --filter billzo-worker start",
    "build:shared": "pnpm --filter @billzo/shared build",
    "build:worker": "pnpm --filter billzo-worker build",
    "build:frontend": "pnpm --filter mini_saas_frontend build",
    "typecheck:frontend": "pnpm --filter mini_saas_frontend typecheck",
    "test": "pnpm -r --sequential test",
    "test:frontend": "pnpm --filter mini_saas_frontend test",
    "test:worker": "pnpm --filter billzo-worker test",
    "test:shared": "pnpm --filter @billzo/shared test"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
